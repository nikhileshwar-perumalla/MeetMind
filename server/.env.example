# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/meetmind

# ─── Vector store (ChromaDB) ──────────────────────────────
CHROMA_URL=http://localhost:8000

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (optional — leave blank to disable the "Sign in with Google" button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── OpenAI (required for AI features) ────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Integrations (optional) ──────────────────────────────
# Jira (Atlassian Cloud REST v3, basic auth with API token)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Slack (bot token, chat:write scope)
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general

# ─── Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=100
